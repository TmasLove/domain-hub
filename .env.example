# ============================================================================
# Domain Flipping & Management Suite Configuration
# ============================================================================
# Copy this file to .env and fill in your credentials
# .env is in .gitignore and will not be committed

# ── Namecheap API (OPTIONAL) ──────────────────────────────────────────────
# For real domain checking and registration through Namecheap
# Get these from: https://www.namecheap.com/support/api/
# Leave blank to use free WHOIS DNS lookups instead

NAMECHEAP_API_KEY=
NAMECHEAP_USER=

# ── Provider Configuration ────────────────────────────────────────────────
# Control which providers are enabled (true/false)
# When multiple are enabled, they're tried in order: Namecheap → WHOIS → Mock

# Real Namecheap API (requires credentials above)
USE_NAMECHEAP=false

# Free WHOIS DNS lookup (no credentials needed)
# Checks if domain is registered via DNS queries
# Slower (~2-3 seconds) but completely free
USE_WHOIS_LOOKUP=true

# Mock/demo mode (always works)
# Returns randomized availability and demo pricing
# Useful for testing without external API calls
USE_MOCK=true

# ── Server Configuration ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ============================================================================
# Setup Instructions:
# ============================================================================
#
# 1. Demo Mode (default, no API keys needed):
#    - Leave NAMECHEAP_API_KEY empty
#    - Set USE_WHOIS_LOOKUP=true and USE_MOCK=true
#    - Will use free DNS lookups with mock fallback
#
# 2. Namecheap Mode (for real registrations):
#    - Sign up at https://www.namecheap.com/
#    - Enable API: https://www.namecheap.com/support/api/
#    - Copy your API Key to NAMECHEAP_API_KEY
#    - Copy your username to NAMECHEAP_USER
#    - Set USE_NAMECHEAP=true
#
# 3. Free WHOIS Only (real availability, zero cost):
#    - Leave NAMECHEAP_API_KEY empty
#    - Set USE_WHOIS_LOOKUP=true
#    - Set USE_MOCK=false (for pure real data)
#    - Note: slower than Namecheap but completely free
#
# ============================================================================
